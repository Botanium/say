#!/usr/bin/env bash
set -euo pipefail

rate=170
speed=""
voice=""
save_to=""
foreground=0
dry_run=0
raw=0
stop=0
next=0
list_voices=0
input_file=""
force_clipboard=0
force_latest=0
timeout=180
auto_action=""
focus_current=0
queue_status=0
drain_queue_internal=0
drain_queue_label=""
set_active_thread=""
watch_next_internal=0
watch_auto_internal=0
watch_session_path=""
watch_baseline_lines=""
watch_launch_label=""
watch_auto_state_dir=""
watch_auto_label=""
args=()
self_path="$(
  cd "$(dirname "${BASH_SOURCE[0]}")"
  pwd
)/$(basename "${BASH_SOURCE[0]}")"

usage() {
  cat <<'USAGE'
codex-say - local no-key read-aloud helper for Codex/chat text

Usage:
  codex-say                         Read the macOS clipboard aloud
  codex-say "text to read"          Read the given text aloud
  codex-say -f report.md            Read a file aloud
  codex-say report.md               Read a file aloud if the path exists
  codex-say --latest                Read the latest assistant message in this Codex thread
  codex-say next                    Speak the next assistant message when it is written
  codex-say auto on                 Speak every future final answer in this thread
  codex-say auto off                Disable automatic read-aloud for this thread
  codex-say auto status             Show automatic read-aloud status
  codex-say auto speed 1.5x         Enable or update automatic read-aloud speed
  codex-say focus                   Mark this Codex thread active and read queued auto speech
  codex-say queue                   Show queued automatic read-aloud responses
  pbpaste | codex-say               Read piped text aloud

Useful options:
  -r, --rate N                      Speech rate, default 170
      --speed X                     Speech multiplier, e.g. 1x, 1.25x, 1.5x, 2x
  -v, --voice NAME                  macOS voice name
  -f, --file PATH                   Read this file
      --clipboard                   Read from macOS clipboard
      --latest                      Read latest assistant message from local Codex transcript
      --next                        Wait for and read next assistant message
      --timeout N                   Timeout in seconds for --next, default 180
      --auto on|off|status          Manage thread automatic read-aloud
      --focus                       Mark this Codex thread active
      --queue-status                Show queued automatic read-aloud responses
      --raw                         Do not clean Markdown before speaking
      --foreground                  Wait until speech finishes
      --save PATH                   Save speech audio instead of playing
      --stop                        Stop current macOS say speech
      --list-voices                 List installed macOS voices
      --dry-run                     Show what would happen without speaking
  -h, --help                        Show this help
USAGE
}

rate_for_speed() {
  /usr/bin/python3 - "$1" <<'PY'
import re
import sys

raw = sys.argv[1].strip().lower()
aliases = {
    "slow": 0.85,
    "normal": 1.0,
    "fast": 1.25,
    "faster": 1.5,
    "double": 2.0,
}
if raw in aliases:
    multiplier = aliases[raw]
else:
    match = re.fullmatch(r"([0-9]+(?:\.[0-9]+)?)x?", raw)
    if not match:
        print(f"Invalid speed: {sys.argv[1]}", file=sys.stderr)
        sys.exit(2)
    multiplier = float(match.group(1))

if multiplier <= 0 or multiplier > 3:
    print("Speed must be greater than 0 and at most 3x.", file=sys.stderr)
    sys.exit(2)

print(round(170 * multiplier))
PY
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -r|--rate)
      rate="${2:?Missing value for $1}"
      shift 2
      ;;
    --speed)
      speed="${2:?Missing value for $1}"
      rate="$(rate_for_speed "$speed")"
      shift 2
      ;;
    -v|--voice)
      voice="${2:?Missing value for $1}"
      shift 2
      ;;
    -f|--file)
      input_file="${2:?Missing value for $1}"
      shift 2
      ;;
    --clipboard)
      force_clipboard=1
      shift
      ;;
    clipboard)
      force_clipboard=1
      shift
      ;;
    --latest)
      force_latest=1
      shift
      ;;
    latest)
      force_latest=1
      shift
      ;;
    --next|next)
      next=1
      shift
      ;;
    --timeout)
      timeout="${2:?Missing value for $1}"
      shift 2
      ;;
    --watch-next-internal)
      watch_next_internal=1
      watch_session_path="${2:?Missing session path for $1}"
      watch_baseline_lines="${3:?Missing baseline line count for $1}"
      timeout="${4:?Missing timeout for $1}"
      rate="${5:?Missing rate for $1}"
      voice="${6:-}"
      watch_launch_label="${7:-}"
      shift 7
      ;;
    --watch-auto-internal)
      watch_auto_internal=1
      watch_auto_state_dir="${2:?Missing state dir for $1}"
      watch_auto_label="${3:-}"
      shift 3
      ;;
    --drain-queue-internal)
      drain_queue_internal=1
      drain_queue_label="${2:-}"
      if [[ $# -ge 2 && -n "${2:-}" && "${2:-}" != --* ]]; then
        shift 2
      else
        shift
      fi
      ;;
    --set-active-thread)
      set_active_thread="${2:?Missing thread id for $1}"
      shift 2
      ;;
    --auto)
      auto_action="${2:-status}"
      if [[ "$auto_action" == "speed" ]]; then
        rate="$(rate_for_speed "${3:?Missing speed value for --auto speed}")"
        auto_action="on"
        shift 3
      elif [[ "$auto_action" == "rate" ]]; then
        rate="${3:?Missing rate value for --auto rate}"
        auto_action="on"
        shift 3
      else
        shift "$(( $# >= 2 ? 2 : 1 ))"
      fi
      ;;
    auto)
      auto_action="${2:-status}"
      if [[ "$auto_action" == "speed" ]]; then
        rate="$(rate_for_speed "${3:?Missing speed value for auto speed}")"
        auto_action="on"
        shift 3
      elif [[ "$auto_action" == "rate" ]]; then
        rate="${3:?Missing rate value for auto rate}"
        auto_action="on"
        shift 3
      else
        shift "$(( $# >= 2 ? 2 : 1 ))"
      fi
      ;;
    --focus|focus)
      focus_current=1
      shift
      ;;
    --queue-status|queue)
      queue_status=1
      shift
      ;;
    --raw)
      raw=1
      shift
      ;;
    --foreground)
      foreground=1
      shift
      ;;
    --save)
      save_to="${2:?Missing value for $1}"
      shift 2
      ;;
    --stop|stop)
      stop=1
      shift
      ;;
    --list-voices)
      list_voices=1
      shift
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      args+=("$@")
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
esac
done

read_latest_codex_message() {
  /usr/bin/python3 - <<'PY'
import glob
import json
import os
import sys

thread_id = os.environ.get("CODEX_THREAD_ID", "").strip()
home = os.path.expanduser("~")
if not thread_id:
    sys.exit(1)

paths = glob.glob(os.path.join(home, ".codex", "sessions", "**", f"*{thread_id}.jsonl"), recursive=True)
paths = [path for path in paths if os.path.isfile(path)]
if not paths:
    sys.exit(1)

path = max(paths, key=os.path.getmtime)
latest_final = ""
latest_any = ""

def extract_text(content):
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    parts = []
    for item in content:
        if isinstance(item, str):
            parts.append(item)
        elif isinstance(item, dict):
            text = item.get("text") or item.get("content") or item.get("output_text")
            if isinstance(text, str):
                parts.append(text)
    return "\n".join(part for part in parts if part.strip())

with open(path, "r", encoding="utf-8") as handle:
    for line in handle:
        try:
            record = json.loads(line)
        except json.JSONDecodeError:
            continue
        if record.get("type") != "response_item":
            continue
        payload = record.get("payload") or {}
        if payload.get("type") != "message" or payload.get("role") != "assistant":
            continue
        text = extract_text(payload.get("content"))
        if text.strip():
            latest_any = text
            if payload.get("phase") == "final_answer":
                latest_final = text

latest = latest_final or latest_any
if not latest.strip():
    sys.exit(1)
sys.stdout.write(latest)
PY
}

current_codex_session_path() {
  /usr/bin/python3 - <<'PY'
import glob
import os
import sys

thread_id = os.environ.get("CODEX_THREAD_ID", "").strip()
home = os.path.expanduser("~")
if not thread_id:
    sys.exit(1)

paths = glob.glob(os.path.join(home, ".codex", "sessions", "**", f"*{thread_id}.jsonl"), recursive=True)
paths = [path for path in paths if os.path.isfile(path)]
if not paths:
    sys.exit(1)

sys.stdout.write(max(paths, key=os.path.getmtime))
PY
}

codex_say_state_root() {
  printf '%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}/codex-say"
}

codex_say_global_state_dir() {
  printf '%s\n' "$(codex_say_state_root)/global"
}

codex_say_queue_dir() {
  printf '%s\n' "$(codex_say_global_state_dir)/queue"
}

codex_say_speaker_lock_dir() {
  printf '%s\n' "$(codex_say_global_state_dir)/speaker.lock"
}

codex_say_stop_marker_path() {
  printf '%s\n' "$(codex_say_global_state_dir)/stop_requested_at"
}

auto_state_dir_for_thread() {
  /usr/bin/python3 - <<'PY'
import hashlib
import os
import re
import sys

thread_id = os.environ.get("CODEX_THREAD_ID", "").strip()
if not thread_id:
    sys.exit(1)

digest = hashlib.sha1(thread_id.encode("utf-8")).hexdigest()[:8]
safe = re.sub(r"[^A-Za-z0-9_.-]+", "-", thread_id).strip(".-_") or "thread"
safe = safe[:72]
home = os.path.expanduser("~")
state_home = os.environ.get("XDG_STATE_HOME") or os.path.join(home, ".local", "state")
sys.stdout.write(os.path.join(state_home, "codex-say", f"{safe}-{digest}"))
PY
}

auto_launch_label_for_thread() {
  /usr/bin/python3 - <<'PY'
import hashlib
import os
import re
import sys

thread_id = os.environ.get("CODEX_THREAD_ID", "").strip()
if not thread_id:
    sys.exit(1)

digest = hashlib.sha1(thread_id.encode("utf-8")).hexdigest()[:8]
safe = re.sub(r"[^A-Za-z0-9_.-]+", "-", thread_id).strip(".-_") or "thread"
safe = safe[:48]
sys.stdout.write(f"com.botanium.codex-say-auto.{safe}.{digest}")
PY
}

launchd_label_active() {
  label="${1:?Missing launchd label}"
  /bin/launchctl print "gui/$(/usr/bin/id -u)/$label" >/dev/null 2>&1
}

auto_enabled_current_thread() {
  state_dir="$(auto_state_dir_for_thread 2>/dev/null)" || return 1
  label="$(auto_launch_label_for_thread 2>/dev/null)" || return 1
  [[ -f "$state_dir/enabled" ]] && launchd_label_active "$label"
}

read_next_codex_message() {
  /usr/bin/python3 - "$watch_session_path" "$watch_baseline_lines" "$timeout" <<'PY'
import json
import os
import sys
import time

path = sys.argv[1]
baseline = int(sys.argv[2])
timeout = float(sys.argv[3])
started = time.time()

def extract_text(content):
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    parts = []
    for item in content:
        if isinstance(item, str):
            parts.append(item)
        elif isinstance(item, dict):
            text = item.get("text") or item.get("content") or item.get("output_text")
            if isinstance(text, str):
                parts.append(text)
    return "\n".join(part for part in parts if part.strip())

while time.time() - started < timeout:
    try:
        with open(path, "r", encoding="utf-8") as handle:
            for line_number, line in enumerate(handle, 1):
                if line_number <= baseline:
                    continue
                try:
                    record = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if record.get("type") != "response_item":
                    continue
                payload = record.get("payload") or {}
                if payload.get("type") != "message" or payload.get("role") != "assistant":
                    continue
                if payload.get("phase") != "final_answer":
                    continue
                text = extract_text(payload.get("content"))
                if text.strip():
                    sys.stdout.write(text)
                    sys.exit(0)
    except FileNotFoundError:
        pass
    time.sleep(0.25)

sys.exit(2)
PY
}

read_auto_codex_message() {
  /usr/bin/python3 - "$watch_auto_state_dir" <<'PY'
import json
import os
import sys
import time

state_dir = sys.argv[1]
enabled_path = os.path.join(state_dir, "enabled")
session_path_path = os.path.join(state_dir, "session_path")
cursor_path = os.path.join(state_dir, "cursor")

def read_text(path, default=""):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.read().strip()
    except FileNotFoundError:
        return default

def write_text(path, value):
    tmp = f"{path}.tmp"
    with open(tmp, "w", encoding="utf-8") as handle:
        handle.write(str(value))
        handle.write("\n")
    os.replace(tmp, path)

def extract_text(content):
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    parts = []
    for item in content:
        if isinstance(item, str):
            parts.append(item)
        elif isinstance(item, dict):
            text = item.get("text") or item.get("content") or item.get("output_text")
            if isinstance(text, str):
                parts.append(text)
    return "\n".join(part for part in parts if part.strip())

while True:
    if not os.path.exists(enabled_path):
        sys.exit(3)

    session_path = read_text(session_path_path)
    try:
        cursor = int(read_text(cursor_path, "0") or "0")
    except ValueError:
        cursor = 0

    if not session_path:
        time.sleep(0.25)
        continue

    current_line = 0
    try:
        with open(session_path, "r", encoding="utf-8") as handle:
            for line_number, line in enumerate(handle, 1):
                current_line = line_number
                if line_number <= cursor:
                    continue
                try:
                    record = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if record.get("type") != "response_item":
                    continue
                payload = record.get("payload") or {}
                if payload.get("type") != "message" or payload.get("role") != "assistant":
                    continue
                if payload.get("phase") != "final_answer":
                    continue
                text = extract_text(payload.get("content"))
                write_text(cursor_path, line_number)
                if text.strip():
                    sys.stdout.write(text)
                    sys.exit(0)
    except FileNotFoundError:
        time.sleep(0.25)
        continue

    if current_line != cursor:
        write_text(cursor_path, current_line)
    time.sleep(0.25)
PY
}

clean_markdown_text() {
  /usr/bin/perl -0pe '
    s/\r\n/\n/g;
    s/```[^\n]*\n.*?```/\n/gs;
    s/`([^`\n]+)`/$1/g;
    s/!\[([^\]]*)\]\([^)]+\)/$1/g;
    s/\[([^\]]+)\]\([^)]+\)/$1/g;
    s/^\s{0,3}#{1,6}\s*//mg;
    s/^\s{0,3}>\s?//mg;
    s/^\s*[-*+]\s+//mg;
    s/^\s*\d+[.)]\s+//mg;
    s/^\s*\|(.+)\|\s*$/ $1 /mg;
    s/\|/ , /g;
    s/[ \t]+/ /g;
    s/\n{3,}/\n\n/g;
  '
}

cleanup_codex_say_processes() {
  include_next="${1:-0}"
  include_auto="${2:-0}"
  /usr/bin/python3 - "$include_next" "$include_auto" <<'PY'
import os
import re
import subprocess
import sys
import time

include_next = sys.argv[1] == "1"
include_auto = sys.argv[2] == "1"
own_pid = os.getpid()
parent_pid = os.getppid()

active_patterns = [
    "/usr/bin/say",
    "text_file=",
]
next_watcher_patterns = [
    "codex-say --watch-next-internal",
    "codex-say' '--watch-next-internal",
]
auto_watcher_patterns = [
    "codex-say --watch-auto-internal",
    "codex-say' '--watch-auto-internal",
]

def remove_launchd_jobs():
    try:
        printed = subprocess.run(
            ["launchctl", "print", f"gui/{os.getuid()}"],
            text=True,
            capture_output=True,
            check=False,
        ).stdout
    except Exception:
        return
    labels = sorted(set(re.findall(r"com\.botanium\.codex-say[^\s]+", printed)))
    for label in labels:
        remove = label.startswith("com.botanium.codex-say.")
        remove = remove or (include_next and label.startswith("com.botanium.codex-say-next."))
        remove = remove or (include_auto and label.startswith("com.botanium.codex-say-auto."))
        if not remove:
            continue
        subprocess.run(
            ["launchctl", "remove", label],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )

def matching_pids():
    out = subprocess.run(
        ["ps", "ax", "-o", "pid=,ppid=,command="],
        text=True,
        capture_output=True,
        check=False,
    ).stdout
    matches = []
    for line in out.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(None, 2)
        if len(parts) < 3:
            continue
        pid = int(parts[0])
        cmd = parts[2]
        if pid in {own_pid, parent_pid}:
            continue
        if "ps ax -o" in cmd or "rg codex-say" in cmd:
            continue
        should_kill = any(pattern in cmd for pattern in active_patterns)
        if include_next:
            should_kill = should_kill or any(pattern in cmd for pattern in next_watcher_patterns)
        if include_auto:
            should_kill = should_kill or any(pattern in cmd for pattern in auto_watcher_patterns)
        if should_kill:
            matches.append(pid)
    return matches

remove_launchd_jobs()

for sig in (15, 9):
    for _ in range(8):
        pids = matching_pids()
        if not pids:
            break
        for pid in pids:
            try:
                os.kill(pid, sig)
            except ProcessLookupError:
                pass
        time.sleep(0.2)
    if not matching_pids():
        break

remove_launchd_jobs()
PY
}

kill_auto_watcher_for_state() {
  state_dir="${1:?Missing auto state dir}"
  /usr/bin/python3 - "$state_dir" <<'PY'
import os
import signal
import subprocess
import sys
import time

state_dir = os.path.realpath(sys.argv[1])
own_pid = os.getpid()
parent_pid = os.getppid()

def matching_pids():
    out = subprocess.run(
        ["ps", "ax", "-o", "pid=,ppid=,command="],
        text=True,
        capture_output=True,
        check=False,
    ).stdout
    matches = []
    for line in out.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(None, 2)
        if len(parts) < 3:
            continue
        pid = int(parts[0])
        cmd = parts[2]
        if pid in {own_pid, parent_pid}:
            continue
        if "--watch-auto-internal" in cmd and state_dir in cmd:
            matches.append(pid)
    return matches

for sig in (signal.SIGTERM, signal.SIGKILL):
    for _ in range(8):
        pids = matching_pids()
        if not pids:
            sys.exit(0)
        for pid in pids:
            try:
                os.kill(pid, sig)
            except ProcessLookupError:
                pass
        time.sleep(0.2)
PY
}

current_thread_id() {
  thread_id="${CODEX_THREAD_ID:-}"
  if [[ -z "$thread_id" ]]; then
    return 1
  fi
  printf '%s\n' "$thread_id"
}

thread_id_from_session_path() {
  session_path="${1:-}"
  /usr/bin/python3 - "$session_path" <<'PY'
import os
import re
import sys

name = os.path.basename(sys.argv[1])
match = re.search(r"([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})\.jsonl$", name)
if not match:
    sys.exit(1)
sys.stdout.write(match.group(1))
PY
}

read_active_thread_id() {
  /bin/cat "$(codex_say_global_state_dir)/active_thread_id" 2>/dev/null || true
}

request_speech_stop() {
  global_dir="$(codex_say_global_state_dir)"
  /bin/mkdir -p "$global_dir"
  /usr/bin/python3 - <<'PY' > "$(codex_say_stop_marker_path)"
import time
print(time.time_ns())
PY
}

speech_stop_marker_value() {
  /bin/cat "$(codex_say_stop_marker_path)" 2>/dev/null || true
}

mark_thread_active() {
  thread_id="${1:-}"
  session_path="${2:-}"
  if [[ -z "$thread_id" ]]; then
    return 0
  fi

  global_dir="$(codex_say_global_state_dir)"
  /bin/mkdir -p "$global_dir"
  old_thread_id="$(read_active_thread_id)"

  printf '%s\n' "$thread_id" > "$global_dir/active_thread_id.tmp"
  /bin/mv "$global_dir/active_thread_id.tmp" "$global_dir/active_thread_id"
  if [[ -n "$session_path" ]]; then
    printf '%s\n' "$session_path" > "$global_dir/active_session_path.tmp"
    /bin/mv "$global_dir/active_session_path.tmp" "$global_dir/active_session_path"
  fi
  /bin/date +%s > "$global_dir/active_updated_at"

  if [[ -n "$old_thread_id" && "$old_thread_id" != "$thread_id" ]]; then
    cleanup_codex_say_processes 1 0
  fi
}

mark_current_thread_active() {
  thread_id="$(current_thread_id 2>/dev/null)" || return 0
  session_path="$(current_codex_session_path 2>/dev/null || true)"
  mark_thread_active "$thread_id" "$session_path"
}

queue_item_dir_for_response() {
  queue_dir="${1:?Missing queue dir}"
  thread_id="${2:?Missing thread id}"
  line_number="${3:?Missing transcript line number}"
  session_path="${4:-}"
  /usr/bin/python3 - "$queue_dir" "$thread_id" "$line_number" "$session_path" <<'PY'
import hashlib
import os
import re
import sys

queue_dir, thread_id, line_number, session_path = sys.argv[1:5]
safe_thread = re.sub(r"[^A-Za-z0-9_.-]+", "-", thread_id).strip(".-_") or "thread"
safe_thread = safe_thread[:72]
digest = hashlib.sha1(f"{thread_id}\0{line_number}\0{session_path}".encode("utf-8")).hexdigest()[:12]
sys.stdout.write(os.path.join(queue_dir, f"{safe_thread}-{line_number}-{digest}"))
PY
}

queue_auto_response() {
  thread_id="${1:?Missing thread id}"
  session_path="${2:-}"
  line_number="${3:-0}"
  text="${4:-}"
  item_rate="${5:-$rate}"
  item_voice="${6:-}"

  if [[ -z "${text//[[:space:]]/}" ]]; then
    return 0
  fi

  queue_dir="$(codex_say_queue_dir)"
  /bin/mkdir -p "$queue_dir"
  item_dir="$(queue_item_dir_for_response "$queue_dir" "$thread_id" "$line_number" "$session_path")"

  if [[ -f "$item_dir/status" ]]; then
    status="$(/bin/cat "$item_dir/status" 2>/dev/null || true)"
    if [[ "$status" != "writing" ]]; then
      return 0
    fi
  fi

  /bin/mkdir -p "$item_dir"
  printf 'writing\n' > "$item_dir/status"
  printf '%s\n' "$thread_id" > "$item_dir/thread_id"
  printf '%s\n' "$session_path" > "$item_dir/session_path"
  printf '%s\n' "$line_number" > "$item_dir/line"
  printf '%s\n' "$item_rate" > "$item_dir/rate"
  printf '%s\n' "$item_voice" > "$item_dir/voice"
  /bin/date +%s > "$item_dir/created_at"
  printf '0\n' > "$item_dir/chunk_index"
  /bin/rm -rf "$item_dir/chunks"
  printf '%s\n' "$text" > "$item_dir/text"
  printf 'pending\n' > "$item_dir/status"
}

next_queue_item_for_thread() {
  queue_dir="$(codex_say_queue_dir)"
  thread_id="${1:-}"
  /usr/bin/python3 - "$queue_dir" "$thread_id" <<'PY'
import os
import sys

queue_dir, thread_id = sys.argv[1:3]

def read_text(path, default=""):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.read().strip()
    except FileNotFoundError:
        return default

if not thread_id or not os.path.isdir(queue_dir):
    sys.exit(0)

items = []
for name in os.listdir(queue_dir):
    path = os.path.join(queue_dir, name)
    if not os.path.isdir(path):
        continue
    status = read_text(os.path.join(path, "status"))
    if status not in {"pending", "speaking"}:
        continue
    if read_text(os.path.join(path, "thread_id")) != thread_id:
        continue
    try:
        created_at = int(read_text(os.path.join(path, "created_at"), "0") or "0")
    except ValueError:
        created_at = 0
    try:
        line_number = int(read_text(os.path.join(path, "line"), "0") or "0")
    except ValueError:
        line_number = 0
    items.append((created_at, line_number, path))

for _, _, path in sorted(items):
    print(path)
PY
}

prepare_queue_chunks() {
  item_dir="${1:?Missing queue item dir}"
  chunks_dir="$item_dir/chunks"
  if [[ -d "$chunks_dir" ]]; then
    return 0
  fi

  tmp_chunks="$item_dir/chunks.tmp.$$"
  /bin/rm -rf "$tmp_chunks"
  /bin/mkdir -p "$tmp_chunks"
  /usr/bin/python3 - "$item_dir/text" "$tmp_chunks" <<'PY'
import os
import re
import sys

text_path, chunks_dir = sys.argv[1:3]
with open(text_path, "r", encoding="utf-8") as handle:
    text = handle.read().strip()

paragraphs = [part.strip() for part in re.split(r"\n\s*\n+", text) if part.strip()]
chunks = []

def append_piece(piece):
    piece = re.sub(r"\s+", " ", piece).strip()
    if not piece:
        return
    max_chars = 420
    if len(piece) <= max_chars:
        chunks.append(piece)
        return
    words = piece.split()
    current = []
    current_len = 0
    for word in words:
        extra = len(word) + (1 if current else 0)
        if current and current_len + extra > max_chars:
            chunks.append(" ".join(current))
            current = [word]
            current_len = len(word)
        else:
            current.append(word)
            current_len += extra
    if current:
        chunks.append(" ".join(current))

for paragraph in paragraphs or [text]:
    sentences = re.split(r"(?<=[.!?])\s+", paragraph)
    current = []
    current_len = 0
    for sentence in sentences:
        sentence = sentence.strip()
        if not sentence:
            continue
        extra = len(sentence) + (1 if current else 0)
        if current and current_len + extra > 420:
            append_piece(" ".join(current))
            current = [sentence]
            current_len = len(sentence)
        else:
            current.append(sentence)
            current_len += extra
    if current:
        append_piece(" ".join(current))

if not chunks and text:
    chunks = [text]

for index, chunk in enumerate(chunks):
    with open(os.path.join(chunks_dir, f"{index:06d}.txt"), "w", encoding="utf-8") as handle:
        handle.write(chunk)
        handle.write("\n")
PY
  /bin/mv "$tmp_chunks" "$chunks_dir"
}

speak_queue_item() {
  item_dir="${1:?Missing queue item dir}"
  thread_id="$(/bin/cat "$item_dir/thread_id" 2>/dev/null || true)"
  item_rate="$(/bin/cat "$item_dir/rate" 2>/dev/null || printf '%s' "$rate")"
  item_voice="$(/bin/cat "$item_dir/voice" 2>/dev/null || true)"

  if [[ -z "$thread_id" ]]; then
    /bin/rm -rf "$item_dir"
    return 0
  fi

  prepare_queue_chunks "$item_dir"
  stop_marker_before="$(speech_stop_marker_value)"

  while true; do
    if [[ "$(read_active_thread_id)" != "$thread_id" ]]; then
      printf 'pending\n' > "$item_dir/status"
      return 1
    fi
    if [[ "$(speech_stop_marker_value)" != "$stop_marker_before" ]]; then
      printf 'pending\n' > "$item_dir/status"
      return 1
    fi

    chunk_index="$(/bin/cat "$item_dir/chunk_index" 2>/dev/null || printf '0')"
    if [[ ! "$chunk_index" =~ ^[0-9]+$ ]]; then
      chunk_index=0
    fi

    chunk_file="$(/bin/ls "$item_dir/chunks"/*.txt 2>/dev/null | /usr/bin/sort | /usr/bin/sed -n "$((chunk_index + 1))p")"
    if [[ -z "$chunk_file" ]]; then
      printf 'done\n' > "$item_dir/status"
      /bin/rm -rf "$item_dir"
      return 0
    fi

    printf 'speaking\n' > "$item_dir/status"
    if [[ -n "$item_voice" ]]; then
      /usr/bin/say -v "$item_voice" -r "$item_rate" -f "$chunk_file" || true
    else
      /usr/bin/say -r "$item_rate" -f "$chunk_file" || true
    fi

    if [[ "$(speech_stop_marker_value)" != "$stop_marker_before" ]]; then
      printf 'pending\n' > "$item_dir/status"
      return 1
    fi
    if [[ "$(read_active_thread_id)" != "$thread_id" ]]; then
      printf 'pending\n' > "$item_dir/status"
      return 1
    fi

    printf '%s\n' "$((chunk_index + 1))" > "$item_dir/chunk_index"
  done
}

drain_active_queue() {
  (
    global_dir="$(codex_say_global_state_dir)"
    lock_dir="$(codex_say_speaker_lock_dir)"
    /bin/mkdir -p "$global_dir"
    lock_attempt=0
    while ! /bin/mkdir "$lock_dir" 2>/dev/null; do
      lock_pid="$(/bin/cat "$lock_dir/pid" 2>/dev/null || true)"
      if [[ -n "$lock_pid" ]] && ! /bin/kill -0 "$lock_pid" 2>/dev/null; then
        /bin/rm -rf "$lock_dir"
      else
        lock_attempt="$((lock_attempt + 1))"
        if [[ "$lock_attempt" -ge 20 ]]; then
          exit 0
        fi
        /bin/sleep 0.25
      fi
    done
    trap '/bin/rm -rf "$lock_dir"' EXIT
    printf '%s\n' "$$" > "$lock_dir/pid"

    while true; do
      active_thread_id="$(read_active_thread_id)"
      if [[ -z "$active_thread_id" ]]; then
        exit 0
      fi
      item_dir="$(next_queue_item_for_thread "$active_thread_id" | /usr/bin/sed -n '1p')"
      if [[ -z "$item_dir" ]]; then
        exit 0
      fi
      if ! speak_queue_item "$item_dir"; then
        exit 0
      fi
    done
  )
}

launch_drain_active_queue() {
  label="com.botanium.codex-say-drain.$(/bin/date +%s).$$.${RANDOM:-0}"
  /bin/launchctl submit -l "$label" -- /bin/bash -c '
    label="$1"
    script="$2"
    trap "/bin/launchctl remove \"$label\" >/dev/null 2>&1 || true" EXIT
    /bin/bash "$script" --drain-queue-internal ""
  ' _ "$label" "$self_path" >/dev/null 2>&1 || (
    /bin/bash "$self_path" --drain-queue-internal "" >/dev/null 2>&1 &
  )
}

show_queue_status() {
  queue_dir="$(codex_say_queue_dir)"
  active_thread_id="$(read_active_thread_id)"
  /usr/bin/python3 - "$queue_dir" "$active_thread_id" <<'PY'
import os
import sys

queue_dir, active_thread_id = sys.argv[1:3]

def read_text(path, default=""):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.read().strip()
    except FileNotFoundError:
        return default

pending = []
if os.path.isdir(queue_dir):
    for name in os.listdir(queue_dir):
        path = os.path.join(queue_dir, name)
        if not os.path.isdir(path):
            continue
        status = read_text(os.path.join(path, "status"))
        if status not in {"pending", "speaking"}:
            continue
        thread_id = read_text(os.path.join(path, "thread_id"))
        line = read_text(os.path.join(path, "line"), "?")
        created_at = read_text(os.path.join(path, "created_at"), "?")
        pending.append((thread_id, line, created_at, status))

if not pending:
    print("No queued auto read-aloud responses.")
else:
    print(f"Queued auto read-aloud responses: {len(pending)}")
    for thread_id, line, created_at, status in sorted(pending, key=lambda item: (item[2], item[1])):
        marker = " active" if active_thread_id and thread_id == active_thread_id else ""
        print(f"- {thread_id} line {line}: {status}{marker}")

if active_thread_id:
    print(f"Active thread: {active_thread_id}")
else:
    print("Active thread: not set")
PY
}

clear_queue_for_thread() {
  thread_id="${1:-}"
  queue_dir="$(codex_say_queue_dir)"
  if [[ -z "$thread_id" || ! -d "$queue_dir" ]]; then
    return 0
  fi
  /usr/bin/python3 - "$queue_dir" "$thread_id" <<'PY'
import os
import shutil
import sys

queue_dir, thread_id = sys.argv[1:3]

def read_text(path, default=""):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.read().strip()
    except FileNotFoundError:
        return default

for name in os.listdir(queue_dir):
    path = os.path.join(queue_dir, name)
    if os.path.isdir(path) and read_text(os.path.join(path, "thread_id")) == thread_id:
        shutil.rmtree(path, ignore_errors=True)
PY
}

show_auto_status() {
  state_dir="$(auto_state_dir_for_thread 2>/dev/null)" || {
    echo "Auto read-aloud is off: no current Codex thread was found."
    return 0
  }
  label="$(auto_launch_label_for_thread)"
  rate_file="$state_dir/rate"
  voice_file="$state_dir/voice"
  session_file="$state_dir/session_path"
  cursor_file="$state_dir/cursor"
  saved_rate="$(/bin/cat "$rate_file" 2>/dev/null || true)"
  saved_voice="$(/bin/cat "$voice_file" 2>/dev/null || true)"
  saved_session="$(/bin/cat "$session_file" 2>/dev/null || true)"
  saved_cursor="$(/bin/cat "$cursor_file" 2>/dev/null || true)"

  if [[ -f "$state_dir/enabled" ]] && launchd_label_active "$label"; then
    echo "Auto read-aloud is on for this Codex thread."
  elif [[ -f "$state_dir/enabled" ]]; then
    echo "Auto read-aloud is configured for this thread, but the watcher is not running."
  else
    echo "Auto read-aloud is off for this Codex thread."
  fi

  if [[ -n "$saved_rate" ]]; then
    echo "Rate: ${saved_rate} wpm"
  fi
  if [[ -n "$saved_voice" ]]; then
    echo "Voice: $saved_voice"
  fi
  if [[ -n "$saved_session" ]]; then
    echo "Transcript: $saved_session"
  fi
  if [[ -n "$saved_cursor" ]]; then
    echo "Cursor line: $saved_cursor"
  fi
  active_thread_id="$(read_active_thread_id)"
  if [[ -n "$active_thread_id" ]]; then
    echo "Active auto thread: $active_thread_id"
  fi
  show_queue_status
}

start_auto_read_aloud() {
  thread_id="$(current_thread_id)" || {
    echo "Auto mode needs a current Codex thread." >&2
    exit 1
  }
  session_path="$(current_codex_session_path)" || {
    echo "Could not find the current Codex session transcript for auto mode." >&2
    exit 1
  }
  state_dir="$(auto_state_dir_for_thread)" || {
    echo "Auto mode needs a current Codex thread." >&2
    exit 1
  }
  label="$(auto_launch_label_for_thread)"
  baseline_lines="$(/usr/bin/wc -l < "$session_path" | /usr/bin/tr -d ' ')"
  cursor="$baseline_lines"

  if [[ -f "$state_dir/enabled" ]] && launchd_label_active "$label"; then
    existing_session="$(/bin/cat "$state_dir/session_path" 2>/dev/null || true)"
    existing_cursor="$(/bin/cat "$state_dir/cursor" 2>/dev/null || true)"
    if [[ "$existing_session" == "$session_path" && "$existing_cursor" =~ ^[0-9]+$ ]]; then
      cursor="$existing_cursor"
    fi
  fi

  /bin/launchctl remove "$label" >/dev/null 2>&1 || true
  if [[ -d "$state_dir" ]]; then
    kill_auto_watcher_for_state "$state_dir" || true
  fi

  /bin/mkdir -p "$state_dir"
  printf '1\n' > "$state_dir/enabled"
  printf '%s\n' "$session_path" > "$state_dir/session_path"
  printf '%s\n' "$cursor" > "$state_dir/cursor"
  printf '%s\n' "$rate" > "$state_dir/rate"
  printf '%s\n' "$voice" > "$state_dir/voice"
  printf '%s\n' "$raw" > "$state_dir/raw"
  printf '%s\n' "$label" > "$state_dir/label"
  printf '%s\n' "$thread_id" > "$state_dir/thread_id"

  mark_thread_active "$thread_id" "$session_path"

  if ! /bin/launchctl submit -l "$label" -- "$self_path" --watch-auto-internal "$state_dir" "$label"; then
    /bin/rm -f "$state_dir/enabled"
    echo "Could not start auto read-aloud watcher." >&2
    exit 1
  fi

  launch_drain_active_queue
  echo "Auto read-aloud is on for this Codex thread at ${rate} wpm. Disable with: codex-say auto off"
}

stop_auto_read_aloud() {
  state_dir="$(auto_state_dir_for_thread 2>/dev/null || true)"
  label="$(auto_launch_label_for_thread 2>/dev/null || true)"

  if [[ -n "$state_dir" && -n "$label" ]]; then
    thread_id="$(current_thread_id 2>/dev/null || true)"
    /bin/rm -f "$state_dir/enabled" 2>/dev/null || true
    /bin/launchctl remove "$label" >/dev/null 2>&1 || true
    kill_auto_watcher_for_state "$state_dir" || true
    /bin/rm -rf "$state_dir" 2>/dev/null || true
    clear_queue_for_thread "$thread_id"
    request_speech_stop
    cleanup_codex_say_processes 1 0
    echo "Auto read-aloud is off for this Codex thread."
  else
    request_speech_stop
    cleanup_codex_say_processes 1 1
    echo "Auto read-aloud is off."
  fi
}

run_auto_watcher() {
  if [[ -n "$watch_auto_label" ]]; then
    trap '/bin/launchctl remove "$watch_auto_label" >/dev/null 2>&1 || true' EXIT
  fi

  while [[ -f "$watch_auto_state_dir/enabled" ]]; do
    if ! text="$(read_auto_codex_message)"; then
      exit 0
    fi
    if [[ -z "${text//[[:space:]]/}" ]]; then
      continue
    fi

    current_rate="$(/bin/cat "$watch_auto_state_dir/rate" 2>/dev/null || printf '%s' "$rate")"
    current_voice="$(/bin/cat "$watch_auto_state_dir/voice" 2>/dev/null || true)"
    current_raw="$(/bin/cat "$watch_auto_state_dir/raw" 2>/dev/null || printf '0')"
    current_session_path="$(/bin/cat "$watch_auto_state_dir/session_path" 2>/dev/null || true)"
    current_line="$(/bin/cat "$watch_auto_state_dir/cursor" 2>/dev/null || printf '0')"
    current_thread_id="$(/bin/cat "$watch_auto_state_dir/thread_id" 2>/dev/null || true)"
    if [[ -z "$current_thread_id" && -n "$current_session_path" ]]; then
      current_thread_id="$(thread_id_from_session_path "$current_session_path" 2>/dev/null || true)"
    fi
    if [[ -z "$current_thread_id" ]]; then
      continue
    fi

    if [[ "$current_raw" != "1" ]]; then
      text="$(printf '%s' "$text" | clean_markdown_text)"
    fi

    queue_auto_response "$current_thread_id" "$current_session_path" "$current_line" "$text" "$current_rate" "$current_voice"
    drain_active_queue
  done
}

case "$auto_action" in
  ""|on|off|status)
    ;;
  *)
    echo "Unknown auto command: $auto_action" >&2
    echo "Use: codex-say auto on | off | status | speed 1.5x | rate 220" >&2
    exit 2
    ;;
esac

if [[ "$drain_queue_internal" -eq 1 ]]; then
  if [[ -n "$drain_queue_label" ]]; then
    trap '/bin/launchctl remove "$drain_queue_label" >/dev/null 2>&1 || true' EXIT
  fi
  drain_active_queue
  exit 0
fi

if [[ -n "$set_active_thread" ]]; then
  mark_thread_active "$set_active_thread" ""
  launch_drain_active_queue
  exit 0
fi

if [[ "$watch_auto_internal" -eq 1 ]]; then
  run_auto_watcher
  exit 0
fi

if [[ "$focus_current" -eq 1 ]]; then
  mark_current_thread_active
  launch_drain_active_queue
  echo "This Codex thread is active for auto read-aloud."
  exit 0
fi

if [[ "$queue_status" -eq 1 ]]; then
  show_queue_status
  exit 0
fi

if [[ "$auto_action" == "status" ]]; then
  show_auto_status
  exit 0
elif [[ "$auto_action" == "off" ]]; then
  stop_auto_read_aloud
  exit 0
elif [[ "$auto_action" == "on" ]]; then
  start_auto_read_aloud
  exit 0
fi

if [[ "$stop" -eq 1 ]]; then
  mark_current_thread_active
  request_speech_stop
  cleanup_codex_say_processes 1 0
  echo "Stopped macOS speech."
  exit 0
fi

if [[ "$next" -eq 1 ]]; then
  mark_current_thread_active
  if auto_enabled_current_thread; then
    echo "Auto read-aloud is already on for this thread; it will speak the next final answer."
    exit 0
  fi
  request_speech_stop
  cleanup_codex_say_processes 1 0
  session_path="$(current_codex_session_path)" || {
    echo "Could not find the current Codex session transcript for --next." >&2
    exit 1
  }
  baseline_lines="$(/usr/bin/wc -l < "$session_path" | /usr/bin/tr -d ' ')"
  label="com.botanium.codex-say-next.$(/bin/date +%s).$$.${RANDOM:-0}"
  if ! /bin/launchctl submit -l "$label" -- "$self_path" --watch-next-internal "$session_path" "$baseline_lines" "$timeout" "$rate" "$voice" "$label"; then
    echo "Could not start next-response speech watcher." >&2
    exit 1
  fi
  echo "Waiting up to ${timeout}s to speak the next Codex response. Stop with: codex-say --stop"
  exit 0
fi

if [[ "$list_voices" -eq 1 ]]; then
  /usr/bin/say -v '?'
  exit 0
fi

mark_current_thread_active

text=""
source_desc="clipboard"

if [[ "$watch_next_internal" -eq 1 ]]; then
  if [[ -n "$watch_launch_label" ]]; then
    trap '/bin/launchctl remove "$watch_launch_label" >/dev/null 2>&1 || true' EXIT
  fi
  if ! text="$(read_next_codex_message)"; then
    exit 1
  fi
  source_desc="next Codex response"
  foreground=1
elif [[ -n "$input_file" ]]; then
  if [[ ! -f "$input_file" ]]; then
    echo "File not found: $input_file" >&2
    exit 1
  fi
  text="$(/bin/cat "$input_file")"
  source_desc="$input_file"
elif [[ "$force_latest" -eq 1 ]]; then
  if ! text="$(read_latest_codex_message)"; then
    echo "Could not find a latest Codex assistant message for this thread." >&2
    exit 1
  fi
  source_desc="latest Codex response"
elif [[ "$force_clipboard" -eq 1 ]]; then
  text="$(/usr/bin/pbpaste)"
  source_desc="clipboard"
elif [[ "${#args[@]}" -eq 1 && -f "${args[0]}" ]]; then
  text="$(/bin/cat "${args[0]}")"
  source_desc="${args[0]}"
elif [[ "${#args[@]}" -gt 0 ]]; then
  text="$(printf '%s ' "${args[@]}")"
  source_desc="argument text"
else
  if [[ ! -t 0 ]]; then
    text="$(/bin/cat || true)"
    source_desc="stdin"
  fi
  if [[ -z "${text//[[:space:]]/}" ]]; then
    if text="$(read_latest_codex_message 2>/dev/null)"; then
      source_desc="latest Codex response"
    fi
  fi
  if [[ -z "${text//[[:space:]]/}" ]]; then
    text="$(/usr/bin/pbpaste)"
    source_desc="clipboard"
  fi
fi

if [[ -z "${text//[[:space:]]/}" ]]; then
  echo "Nothing to read. Copy text first, pass text, pipe text, or use -f FILE." >&2
  exit 1
fi

if [[ "$watch_next_internal" -eq 0 ]]; then
  request_speech_stop
  cleanup_codex_say_processes 1 0
fi

if [[ "$raw" -eq 0 ]]; then
  text="$(printf '%s' "$text" | clean_markdown_text)"
fi

chars="$(printf '%s' "$text" | /usr/bin/wc -c | /usr/bin/tr -d ' ')"

if [[ "$dry_run" -eq 1 ]]; then
  echo "Would speak $chars characters from $source_desc at $rate wpm."
  exit 0
fi

tmp_file="$(/usr/bin/mktemp -t codex-say)"
printf '%s\n' "$text" > "$tmp_file"

say_args=(-r "$rate")
if [[ -n "$voice" ]]; then
  say_args=(-v "$voice" "${say_args[@]}")
fi

if [[ -n "$save_to" ]]; then
  /usr/bin/say "${say_args[@]}" -f "$tmp_file" -o "$save_to"
  /bin/rm -f "$tmp_file"
  echo "Saved speech audio to $save_to."
  exit 0
fi

if [[ "$foreground" -eq 1 ]]; then
  /usr/bin/say "${say_args[@]}" -f "$tmp_file"
  /bin/rm -f "$tmp_file"
else
  label="com.botanium.codex-say.$(/bin/date +%s).$$.${RANDOM:-0}"
  if ! /bin/launchctl submit -l "$label" -- /bin/bash -c '
    label="$1"
    voice="$2"
    rate="$3"
    text_file="$4"
    trap "/bin/launchctl remove \"$label\" >/dev/null 2>&1 || true" EXIT
    if [[ -n "$voice" ]]; then
      /usr/bin/say -v "$voice" -r "$rate" -f "$text_file"
    else
      /usr/bin/say -r "$rate" -f "$text_file"
    fi
    /bin/rm -f "$text_file"
  ' _ "$label" "$voice" "$rate" "$tmp_file"; then
    /bin/rm -f "$tmp_file"
    echo "Could not start background speech with launchctl." >&2
    exit 1
  fi
fi

echo "Speaking $chars characters from $source_desc at $rate wpm. Stop with: codex-say --stop"
